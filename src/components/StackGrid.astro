---
import { stack } from '../data/site';
---

<section id="stack" class="section">
  <div class="wrap">
    <span class="label" style="color:var(--accent)">// The stack</span>
    <h2 class="section-title-alt" style="margin:10px 0 8px">Tools that signal the level.</h2>
    <p class="stack-lead">The ~10 that matter: strategy, craft, analytics and AI, not a logo wall.</p>

    <ul class="stack-grid" data-reveal>
      {stack.map((t) => (
        <li class="tool-chip">
          <span class="tool-dot" style={`background:${t.dot}`}></span>
          {t.name}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .stack-lead { max-width: 560px; margin: 0 0 26px; font-size: var(--t-body-lg); line-height: 1.6; }
  .stack-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .tool-chip {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.04em;
    background: var(--surface);
    border: var(--bw) solid var(--ink);
    border-radius: var(--r-pill);
    box-shadow: var(--shadow-sm);
    padding: 11px 18px;
    transition: transform var(--t-press), box-shadow var(--t-press), background var(--t-press);
  }
  .tool-chip:hover {
    background: var(--lime);
    transform: translate(3px, 3px);
    box-shadow: 1px 1px 0 var(--ink);
  }
  .tool-dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: 2px solid var(--ink);
    flex: none;
  }
</style>
